{
  "name": "matchshift-txline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "txline:activate": "tsx src/txline/phantom-activation-cli.ts",
    "txline:smoke": "tsx src/txline/smoke-cli.ts",
    "txline:smoke-reference": "tsx src/txline/reference-sse-smoke-cli.ts",
    "txline:probe-shape": "tsx src/txline/historical-shape-probe-cli.ts",
    "txline:probe-odds-shape": "tsx src/txline/historical-odds-shape-probe-cli.ts",
    "txline:provenance": "tsx src/txline/solana-provenance-cli.ts",
    "txline:live-observe": "tsx src/txline/live-observer-window-cli.ts",
    "txline:live-snapshot-observe": "tsx src/txline/live-snapshot-observer-cli.ts",
    "txline:live-odds-transport-observe": "tsx src/txline/live-odds-transport-observer-cli.ts",
    "txline:live-record": "tsx src/txline/live-match-recorder-cli.ts",
    "txline:export-curated-replay": "tsx src/txline/curated-replay-export-cli.ts"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
